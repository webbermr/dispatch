{
  "name": "@dispatch/server",
  "version": "0.1.0",
  "description": "Dispatch control-plane server — shared board, auth, and live sync for teams.",
  "type": "module",
  "bin": { "dispatch-server": "./dist/index.js" },
  "files": ["dist"],
  "engines": { "node": ">=20" },
  "repository": "github:webbermr/dispatch",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.13",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
