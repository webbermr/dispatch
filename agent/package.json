{
  "name": "@dispatch/agent",
  "version": "0.1.0",
  "description": "Dispatch local agent — bridges the web board to Codex CLI against your local repos.",
  "type": "module",
  "bin": {
    "dispatch-agent": "./dist/cli.js"
  },
  "files": [
    "dist",
    "web"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "start": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "bundle": "node scripts/bundle-web.mjs",
    "prepack": "npm run build && npm run bundle",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": "github:webbermr/dispatch",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.13",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
